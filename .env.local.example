# Supabase — copia estos valores desde tu proyecto en supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Secret para JWT (genera uno aleatorio largo)
NEXTAUTH_SECRET=cambia-esto-por-un-string-secreto-largo

# URL de tu app (en local siempre esta)
NEXTAUTH_URL=http://localhost:3000
